# Copy to .env for local Expo (same folder). Restart `npx expo start` after changes.

# Public API origin (no trailing slash), e.g. http://192.168.1.5:8000 for a phone on the same LAN.
EXPO_PUBLIC_API_BASE_URL=

# Must match Laravel FRONTEND_API_KEY when production API gate is enabled.
EXPO_PUBLIC_SARS_API_KEY=

# Enforce HTTPS for API_BASE_URL (recommended true in production; set false for local HTTP testing).
EXPO_PUBLIC_ENFORCE_HTTPS=false
