APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# Production: APP_ENV=production, APP_DEBUG=false, APP_URL and FRONTEND_URL must be https.
# See ../DEPLOY.md for a full checklist.

# Frontend origin for student invite links (#/setup-password?token=...). No trailing slash before #.
# Example local: http://127.0.0.1:5500  or  http://127.0.0.1:5500/FE/index.html
FRONTEND_URL=http://127.0.0.1:5501/FE/index.html

# Behind nginx / Cloudflare / load balancer: use * or comma-separated proxy IPs so X-Forwarded-* is trusted.
# TRUSTED_PROXIES=*

# Optional: authenticated API requests per user+minute (default 120).
# API_RATE_LIMIT_PER_MINUTE=120

# Optional: login attempts per identifier+IP per minute (default 10).
# LOGIN_RATE_LIMIT_PER_MINUTE=10

# Optional: Sanctum token lifetime in minutes (empty = no expiry).
# SANCTUM_TOKEN_EXPIRATION=10080

# Production default hides mail/SMS hints on GET /api/health. Set true for internal ops endpoints only.
# HEALTH_SHOW_INTEGRATIONS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# SMS (optional). If any of these are unset, SMS is logged only — see GET /api/health → integrations.sms_mode.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# Browser CORS: comma-separated https origins in production (avoid *).
# CORS_ALLOWED_ORIGINS=*

# Required in APP_ENV=production: same value as window.__SARS_CONFIG__.apiKey in the static frontend.
# Not a substitute for authentication; rate-limit and monitor this header.
FRONTEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
