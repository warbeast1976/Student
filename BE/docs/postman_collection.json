{
  "info": {
    "name": "Student Absence Report System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "" },
    { "key": "teacherToken", "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "sessionId", "value": "1" },
    { "key": "qrPayload", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Login (Teacher)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@example.com\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Login (Student)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Teacher - Attendance Sessions (QR)",
      "item": [
        {
          "name": "Open Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/teacher/attendance-sessions", "host": ["{{baseUrl}}"], "path": ["api", "teacher", "attendance-sessions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"class_id\": 1,\n  \"school_year_id\": 1,\n  \"attendance_date\": \"2026-04-08\",\n  \"duration_minutes\": 15\n}"
            }
          }
        },
        {
          "name": "Get Session QR (SVG)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacherToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/teacher/attendance-sessions/{{sessionId}}/qr?format=svg&size=320",
              "host": ["{{baseUrl}}"],
              "path": ["api", "teacher", "attendance-sessions", "{{sessionId}}", "qr"],
              "query": [
                { "key": "format", "value": "svg" },
                { "key": "size", "value": "320" }
              ]
            }
          }
        },
        {
          "name": "Student Check-in (use qr_payload from Open Session response)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/student/attendance-sessions/check-in",
              "host": ["{{baseUrl}}"],
              "path": ["api", "student", "attendance-sessions", "check-in"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"qr_payload\": \"{{qrPayload}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Audit Logs",
      "item": [
        {
          "name": "List Audit Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/audit-logs", "host": ["{{baseUrl}}"], "path": ["api", "admin", "audit-logs"] }
          }
        }
      ]
    },
    {
      "name": "Import / Export",
      "item": [
        {
          "name": "Admin - Export Users (CSV)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/users-export", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users-export"] }
          }
        },
        {
          "name": "Teacher - Export Attendance (CSV)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacherToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/teacher/attendance-export?class_id=1&from=2026-04-01&to=2026-04-30",
              "host": ["{{baseUrl}}"],
              "path": ["api", "teacher", "attendance-export"],
              "query": [
                { "key": "class_id", "value": "1" },
                { "key": "from", "value": "2026-04-01" },
                { "key": "to", "value": "2026-04-30" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Announcements",
      "item": [
        {
          "name": "Teacher - Create Announcement (draft)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/teacher/announcements", "host": ["{{baseUrl}}"], "path": ["api", "teacher", "announcements"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"class_id\": 1,\n  \"title\": \"Quiz\",\n  \"body\": \"Quiz tomorrow\"\n}"
            }
          }
        },
        {
          "name": "Teacher - Publish Announcement",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/teacher/announcements/1/publish", "host": ["{{baseUrl}}"], "path": ["api", "teacher", "announcements", "1", "publish"] }
          }
        },
        {
          "name": "Student - List Announcements",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/student/announcements", "host": ["{{baseUrl}}"], "path": ["api", "student", "announcements"] }
          }
        }
      ]
    }
  ]
}

